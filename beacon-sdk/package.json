{
  "name": "beacon-protocol-sdk",
  "version": "0.1.1",
  "description": "Node.js SDK for the BEACON Protocol - Agent Safety Layer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters/langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "default": "./dist/adapters/langchain.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "safety",
    "langchain",
    "crewai",
    "beacon",
    "protocol"
  ],
  "author": "BEACON Protocol",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.17.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/uuid": "^10.0.0",
    "typescript": "^6.0.3"
  }
}
